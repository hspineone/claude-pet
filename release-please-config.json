{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "changelog-sections": [
    { "type": "feat", "section": "새 기능" },
    { "type": "fix", "section": "버그 수정" },
    { "type": "perf", "section": "성능 개선" },
    { "type": "revert", "section": "되돌리기" },
    { "type": "refactor", "section": "리팩터링", "hidden": true },
    { "type": "docs", "section": "문서", "hidden": true },
    { "type": "style", "section": "스타일", "hidden": true },
    { "type": "chore", "section": "기타", "hidden": true },
    { "type": "test", "section": "테스트", "hidden": true },
    { "type": "build", "section": "빌드", "hidden": true },
    { "type": "ci", "section": "CI", "hidden": true }
  ],
  "packages": {
    ".": {
      "package-name": "claude-pet",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "generic",
          "path": "gradle.properties"
        }
      ]
    }
  }
}
